# ============================================================
# Stage 1: Build the Vite/React web app
# ============================================================
FROM node:22-alpine AS web-builder
WORKDIR /app

RUN apk add --no-cache python3 make g++

# Copy workspace manifests
COPY package.json package-lock.json turbo.json tsconfig.base.json tsconfig.json ./

# The web app has no internal workspace deps, but npm ci needs the full
# workspace layout to resolve the monorepo structure correctly.
COPY packages/ packages/
COPY apps/web/ apps/web/

RUN npm ci

# Build with empty VITE_API_URL so the client uses relative /api/* paths;
# nginx will proxy those to api-server inside the compose network.
ENV VITE_API_URL=
RUN npm run build --workspace @shuvdex/web

# ============================================================
# Stage 2: Serve with nginx
# ============================================================
FROM nginx:alpine AS web

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Install our custom nginx config
COPY nginx.conf /etc/nginx/nginx.conf

# Copy the compiled Vite build
COPY --from=web-builder /app/apps/web/dist/ /usr/share/nginx/html/

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget -qO- http://localhost/health || exit 1
