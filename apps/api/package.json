    "@shuvdex/capability-registry": "*",
    "@shuvdex/core": "*",
    "@shuvdex/policy-engine": "*",
    "@shuvdex/skill-importer": "*",
    "@shuvdex/skill-indexer": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.0",
    "tsx": "^4.0.0"
  }
}
