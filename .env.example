# ─── Deployment mode ─────────────────────────────────────────────────────────
# Set to "production" for live deployments. Use "development" for local dev
# without auth enforcement.
SHUVDEX_MODE=production

# ─── Service ports ───────────────────────────────────────────────────────────
# Host-side port mappings. Container-internal ports are fixed (3848/3847/80).
MCP_PORT=3848
API_PORT=3847
WEB_PORT=80

# ─── Paths ────────────────────────────────────────────────────────────────────
# Absolute path on the host to the shuvdex repo (or a skills repo) that is
# mounted read-only into containers as /repo. Defaults to the current directory.
LOCAL_REPO_PATH=.

# ─── Identity Provider — Entra ID (Microsoft) ────────────────────────────────
# Required when using Entra ID JWT authentication.
IDP_ENTRA_TENANT_ID=
IDP_ENTRA_AUDIENCE=

# ─── Identity Provider — Google Workspace ────────────────────────────────────
# Required when using Google Workspace OIDC authentication.
IDP_GOOGLE_AUDIENCE=
# Comma-separated list of allowed Google Workspace domains (e.g. example.com)
IDP_GOOGLE_ALLOWED_DOMAINS=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API server.
# Leave blank to use the built-in defaults (localhost:5173 etc.)
# Example: CORS_ALLOWED_ORIGINS=https://shuvdex.example.com
CORS_ALLOWED_ORIGINS=

# ─── Tailscale (optional) ────────────────────────────────────────────────────
# Provide a Tailscale auth key to enable the tailscale sidecar service.
# Start the sidecar with: docker compose --profile tailscale up -d
TS_AUTHKEY=

# ─── Dev mode ────────────────────────────────────────────────────────────────
# Set to "true" to skip authentication enforcement (NOT for production).
DEV_MODE=
