{
  "_comment": "Code Mode MCP configuration. Generated by codemode-scaffold.",
  "scaffold_version": "1.0.0",
  "skill_name": "make-api",
  "adapter_type": "mcp",
  "server": {
    "script": "make_api_server.py",
    "transport": "stdio"
  },
  "policy": {
    "default_timeout_seconds": 30,
    "default_max_calls": 20,
    "result_max_bytes": 50000,
    "console_max_bytes": 10000,
    "allow_unknown_tools": false,
    "read_tools": [
      "scenarios_list", "scenarios_get", "scenarios_logs_list",
      "scenarios_blueprint_get", "scenarios_executions_list",
      "scenarios_executions_get", "scenarios_usage_get", "scenarios_interface_get",
      "connections_list", "connections_get", "connections_editable_schema",
      "data_stores_list", "data_stores_get", "data_stores_records_list",
      "hooks_list", "hooks_get",
      "teams_list", "organizations_list", "users_me",
      "scenario_folders_list"
    ],
    "write_tools": [
      "scenarios_run", "scenarios_start", "scenarios_stop", "scenarios_delete", "scenarios_clone",
      "connections_create", "connections_delete", "connections_rename", "connections_test",
      "data_stores_records_create", "data_stores_records_delete", "data_stores_record_update",
      "hooks_create", "hooks_delete", "hooks_enable", "hooks_disable",
      "hooks_ping", "hooks_learn_start", "hooks_learn_stop"
    ],
    "pattern_rules": [
      {
        "type": "suffix",
        "pattern": "_list",
        "classification": "read"
      },
      {
        "type": "suffix",
        "pattern": "_get",
        "classification": "read"
      },
      {
        "type": "suffix",
        "pattern": "_delete",
        "classification": "write"
      },
      {
        "type": "suffix",
        "pattern": "_create",
        "classification": "write"
      },
      {
        "type": "suffix",
        "pattern": "_update",
        "classification": "write"
      }
    ]
  },
  "cli": {
    "adapter_object_name": "codemode",
    "has_json_flag": true,
    "has_yes_flag": false
  }
}
