{
  "groupId": "core-config",
  "surface": "terminal-node-api",
  "toolsUsed": [
    "node --input-type=module"
  ],
  "assertions": [
    {
      "id": "VAL-INFRA-001",
      "status": "pass",
      "reason": "loadConfig loaded the valid YAML registry, returned two hosts, and allowed direct lookup of shuvtest and localhost through HostRegistry.",
      "evidence": {
        "files": [
          "VAL-INFRA-001-valid-config.yaml",
          "VAL-INFRA-001-load-valid-yaml.mjs",
          "VAL-INFRA-001-load-valid-yaml-output.json"
        ],
        "observations": {
          "hostCount": 2,
          "hostNames": [
            "shuvtest",
            "localhost"
          ],
          "sampleLookup": {
            "hostname": "shuvtest",
            "connectionType": "ssh",
            "port": 22,
            "user": "shuv",
            "timeout": 30
          }
        }
      }
    },
    {
      "id": "VAL-INFRA-002",
      "status": "pass",
      "reason": "The exported HostConfig schema accepted a valid host entry and rejected missing hostname, invalid port, and invalid connectionType inputs with field-level error paths.",
      "evidence": {
        "files": [
          "VAL-INFRA-002-schema-validation.mjs",
          "VAL-INFRA-002-schema-validation-output.json"
        ],
        "observations": {
          "validResult": {
            "hostname": "shuvtest",
            "connectionType": "ssh",
            "port": 2222,
            "user": "shuv",
            "timeout": 60
          },
          "invalidResults": [
            {
              "label": "missing-hostname",
              "input": {
                "port": 22
              },
              "status": "error",
              "message": "(Struct (Encoded side) <-> Struct (Type side))\n\u2514\u2500 Encoded side transformation failure\n   \u2514\u2500 Struct (Encoded side)\n      \u2514\u2500 [\"hostname\"]\n         \u2514\u2500 is missing",
              "mentionsHostname": true,
              "mentionsPort": false,
              "mentionsConnectionType": false
            },
            {
              "label": "invalid-port",
              "input": {
                "hostname": "shuvtest",
                "port": 70000
              },
              "status": "error",
              "message": "(Struct (Encoded side) <-> Struct (Type side))\n\u2514\u2500 Encoded side transformation failure\n   \u2514\u2500 Struct (Encoded side)\n      \u2514\u2500 [\"port\"]\n         \u2514\u2500 Int & between(1, 65535) | undefined\n            \u251c\u2500 Int & between(1, 65535)\n            \u2502  \u2514\u2500 Predicate refinement failure\n            \u2502     \u2514\u2500 Expected a number between 1 and 65535, actual 70000\n            \u2514\u2500 Expected undefined, actual 70000",
              "mentionsHostname": false,
              "mentionsPort": true,
              "mentionsConnectionType": false
            },
            {
              "label": "invalid-connectionType",
              "input": {
                "hostname": "shuvtest",
                "connectionType": "ftp"
              },
              "status": "error",
              "message": "(Struct (Encoded side) <-> Struct (Type side))\n\u2514\u2500 Encoded side transformation failure\n   \u2514\u2500 Struct (Encoded side)\n      \u2514\u2500 [\"connectionType\"]\n         \u2514\u2500 \"ssh\" | \"local\" | undefined\n            \u251c\u2500 \"ssh\" | \"local\"\n            \u2502  \u251c\u2500 Expected \"ssh\", actual \"ftp\"\n            \u2502  \u2514\u2500 Expected \"local\", actual \"ftp\"\n            \u2514\u2500 Expected undefined, actual \"ftp\"",
              "mentionsHostname": false,
              "mentionsPort": false,
              "mentionsConnectionType": true
            }
          ]
        }
      }
    },
    {
      "id": "VAL-INFRA-003",
      "status": "pass",
      "reason": "loadConfig returned a typed ConfigNotFound error for a missing YAML file and preserved the attempted file path without crashing the Node process.",
      "evidence": {
        "files": [
          "VAL-INFRA-003-missing-config-file.mjs",
          "VAL-INFRA-003-missing-config-file-output.json"
        ],
        "observations": {
          "assertionId": "VAL-INFRA-003",
          "filePath": "/tmp/shuvdex-user-testing-core-config/VAL-INFRA-003-missing-config.yaml",
          "unexpectedSuccess": false,
          "error": {
            "tag": "ConfigNotFound",
            "path": "/tmp/shuvdex-user-testing-core-config/VAL-INFRA-003-missing-config.yaml",
            "message": "Configuration file not found: /tmp/shuvdex-user-testing-core-config/VAL-INFRA-003-missing-config.yaml"
          }
        }
      }
    },
    {
      "id": "VAL-INFRA-004",
      "status": "pass",
      "reason": "A minimal YAML host entry received the expected default connectionType, port, and timeout values, while a host entry missing hostname failed validation with a hostname-specific error.",
      "evidence": {
